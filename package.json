{
  "name": "scarce",
  "displayName": "Scarce",
  "description": "Bookmark code you can't fix right now. Leave cairns, find your way back.",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "scarce.addToScarce",
        "title": "Add to Scarce"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "scarce.addToScarce",
          "when": "editorHasSelection",
          "group": "scarce@1"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "scarce",
          "title": "Scarce",
          "icon": "resources/scarce-icon.svg"
        }
      ]
    },
    "views": {
      "scarce": [
        {
          "type": "webview",
          "id": "scarce-cairns",
          "name": "Cairns",
          "icon": "resources/scarce-icon.svg"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm run package",
    "compile": "pnpm run check-types && pnpm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "pnpm run check-types && pnpm run lint && node esbuild.js --production",
    "check-types": "tsc --noEmit",
    "lint": "eslint src"
  },
  "devDependencies": {
    "@types/node": "~22.19.19",
    "@types/vscode": "^1.120.0",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
